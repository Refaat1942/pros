APP_NAME=Laravel
# استخدم production على الخادم الفعلي؛ local للتطوير فقط
APP_ENV=production
APP_KEY=
# يجب أن يبقى false في الإنتاج لمنع كشف آثار الأخطاء والبيانات الحساسة
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# النظام يعمل أوفلاين بالكامل — أبقِ إشعارات تيليجرام معطلة في الإنتاج
# (تُرسِل الروابط والـ IP وآثار الأخطاء خارج الشبكة الداخلية عند تفعيلها)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ERROR_NOTIFY=false

# فرض تأمين الجلسة على HTTPS في الإنتاج
SESSION_SECURE_COOKIE=true

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── Firebase Cloud Messaging (إشعارات بين اللوحات) ──────────────────────────
# server-side (سري): ضع مسار ملف الـ service account، واجعل ENABLED=true للإرسال الفعلي
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=threeth
FIREBASE_CREDENTIALS="${PWD}/firebase/threeth-firebase-adminsdk-fbsvc-66271fdcd8.json"
# web-side (غير سري — يُرسل للمتصفح): من Firebase Console ▸ Project settings ▸ Web app
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_SENDER_ID=
FIREBASE_WEB_APP_ID=
FIREBASE_WEB_VAPID_KEY=
